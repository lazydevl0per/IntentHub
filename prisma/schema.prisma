generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RepositoryRole {
  OWNER
  MEMBER
}

enum ObjectiveStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ObjectivePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PlanStatus {
  DRAFT
  ACTIVE
  REJECTED
  SELECTED
}

enum AgentRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum EvaluationType {
  TEST
  BENCHMARK
  SECURITY
  QUALITY
}

enum DocumentEntityType {
  OBJECTIVE
  PLAN
  DECISION
  EVALUATION
  AGENT_RUN
  COMMIT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  repositoryMembers  RepositoryMember[]
  objectives         Objective[]        @relation("ObjectiveCreator")
  plans              Plan[]
  agentRuns          AgentRun[]
  evaluations        Evaluation[]
  decisions          Decision[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Repository {
  id             String    @id @default(cuid())
  githubId       Int       @unique
  owner          String
  name           String
  fullName       String
  defaultBranch  String    @default("main")
  webhookSecret  String?
  githubWebhookId Int?
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  members     RepositoryMember[]
  objectives  Objective[]
  commits     GitCommit[]
  branches    GitBranch[]
  chunks      DocumentChunk[]

  @@unique([owner, name])
}

model RepositoryMember {
  id           String         @id @default(cuid())
  userId       String
  repositoryId String
  role         RepositoryRole @default(MEMBER)
  createdAt    DateTime       @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([userId, repositoryId])
}

model Objective {
  id           String            @id @default(cuid())
  title        String
  description  String            @db.Text
  status       ObjectiveStatus   @default(DRAFT)
  priority     ObjectivePriority @default(MEDIUM)
  repositoryId String
  creatorId    String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  repository  Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  creator     User         @relation("ObjectiveCreator", fields: [creatorId], references: [id])
  plans       Plan[]
  agentRuns   AgentRun[]
  evaluations Evaluation[]
  decision    Decision?

  @@index([repositoryId])
  @@index([status])
}

model Plan {
  id          String     @id @default(cuid())
  objectiveId String
  title       String
  description String     @db.Text
  approach    String     @db.Text
  status      PlanStatus @default(DRAFT)
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  objective   Objective    @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  createdBy   User         @relation(fields: [createdById], references: [id])
  agentRuns   AgentRun[]
  evaluations Evaluation[]
  decision    Decision?

  @@index([objectiveId])
}

model AgentRun {
  id          String         @id @default(cuid())
  objectiveId String
  planId      String?
  agentName   String
  model       String?
  prompt      String         @db.Text
  output      String         @db.Text
  branchName  String?
  status      AgentRunStatus @default(PENDING)
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  objective   Objective    @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  plan        Plan?        @relation(fields: [planId], references: [id], onDelete: SetNull)
  createdBy   User         @relation(fields: [createdById], references: [id])
  evaluations Evaluation[]

  @@index([objectiveId])
  @@index([planId])
}

model Evaluation {
  id          String         @id @default(cuid())
  objectiveId String
  planId      String?
  agentRunId  String?
  type        EvaluationType
  score       Float
  summary     String         @db.Text
  rawJson     Json?
  createdById String
  createdAt   DateTime       @default(now())

  objective Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  plan      Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  agentRun  AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  createdBy User      @relation(fields: [createdById], references: [id])

  @@index([objectiveId])
}

model Decision {
  id              String   @id @default(cuid())
  objectiveId     String   @unique
  selectedPlanId  String   @unique
  rationale       String   @db.Text
  linkedCommitSha String?
  approvedById    String
  approvedAt      DateTime @default(now())

  objective    Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  selectedPlan Plan      @relation(fields: [selectedPlanId], references: [id])
  approvedBy   User      @relation(fields: [approvedById], references: [id])
}

model GitCommit {
  id           String   @id @default(cuid())
  repositoryId String
  sha          String
  message      String   @db.Text
  author       String
  committedAt  DateTime
  parentShas   String[]

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, sha])
  @@index([repositoryId, committedAt])
}

model GitBranch {
  id           String   @id @default(cuid())
  repositoryId String
  name         String
  headSha      String
  updatedAt    DateTime @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, name])
}

model DocumentChunk {
  id           String             @id @default(cuid())
  repositoryId String
  entityType   DocumentEntityType
  entityId     String
  content      String             @db.Text
  embedding    Unsupported("vector(1536)")?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId])
  @@index([entityType, entityId])
}
